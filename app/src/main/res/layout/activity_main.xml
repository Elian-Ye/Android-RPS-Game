<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/open_settings"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_settings"
            app:tint="@color/rps_text_muted" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/contentArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/txtInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/default_message"
            android:textColor="@color/rps_text_primary"
            android:textSize="23sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtBestStreak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="@color/rps_text_muted"
            android:textSize="13sp"
            tools:text="最高記録：5連勝" />

        <TextView
            android:id="@+id/txtStreakTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="@color/rps_result_win"
            android:textSize="17sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="じゃんけん名人"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/handArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgGu"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_hand_normal"
                android:contentDescription="@string/hand_rock"
                android:padding="7dp"
                android:scaleType="fitCenter"
                android:src="@drawable/j_gu02" />

            <ImageView
                android:id="@+id/imgCh"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_hand_normal"
                android:contentDescription="@string/hand_scissors"
                android:padding="7dp"
                android:scaleType="fitCenter"
                android:src="@drawable/j_ch02" />

            <ImageView
                android:id="@+id/imgPa"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_hand_normal"
                android:contentDescription="@string/hand_paper"
                android:padding="7dp"
                android:scaleType="fitCenter"
                android:src="@drawable/j_pa02" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cpuResult"
            android:layout_width="120dp"
            android:layout_height="58dp"
            android:layout_marginTop="64dp"
            android:background="@drawable/bg_cpu_result"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/txtCpu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:includeFontPadding="false"
                android:text="@string/cpu"
                android:textColor="@color/rps_text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgCpu"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:contentDescription="@string/cpu"
                android:scaleType="fitCenter"
                android:src="@drawable/j_gu02" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/buttonArea"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:paddingBottom="28dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStart"
            android:layout_width="180dp"
            android:layout_height="48dp"
            android:layout_gravity="top|center_horizontal"
            android:background="@drawable/bg_main_button"
            android:backgroundTint="@null"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:stateListAnimator="@null"
            android:text="@string/select_hand_prompt"
            android:textAllCaps="false"
            android:textColor="@color/rps_main_button_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNext"
            android:layout_width="180dp"
            android:layout_height="48dp"
            android:layout_gravity="top|center_horizontal"
            android:background="@drawable/bg_main_button"
            android:backgroundTint="@null"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:stateListAnimator="@null"
            android:text="@string/next"
            android:textAllCaps="false"
            android:textColor="@color/rps_main_button_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
